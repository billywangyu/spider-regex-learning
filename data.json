  "regexExamples": [
    {
      "name": "手机号",
      "pattern": "^(13[0-9]|14[5|7]|15[0-9]|18[0-9])\\\\d{8}$",
      "description": "中国大陆手机号（简单版，支持13/14/15/18开头）",
      "exampleText": "13812345678"
    },
    {
      "name": "邮箱",
      "pattern": "^\\\\w+([-+.]\\\\w+)*@\\\\w+([-.]\\\\w+)*\\\\.\\\\w+([-.]\\\\w+)*$",
      "description": "常见邮箱格式（如 user@example.com）",
      "exampleText": "test@example.com"
    },
    {
      "name": "身份证",
      "pattern": "^[1-9]\\\\d{5}[1-9]\\\\d{3}((0\\\\d)|(1[0-2]))(([012]\\\\d)|3[0-1])\\\\d{3}([0-9Xx])$",
      "description": "18位身份证号码（兼容末尾X）",
      "exampleText": "11010119900307663X"
    },
    {
      "name": "金额",
      "pattern": "^[1-9][0-9]*(\\\\.[0-9]{1,2})?$",
      "description": "正数金额，整数部分≥1，小数部分最多两位",
      "exampleText": "199.99"
    },
    {
      "name": "纯汉字",
      "pattern": "^[\\\\u4e00-\\\\u9fa5]+$",
      "description": "仅中文字符（不含标点）",
      "exampleText": "爬虫工程师"
    },
    {
      "name": "密码",
      "pattern": "^[a-zA-Z]\\\\w{5,17}$",
      "description": "字母开头，长度6~18，仅支持字母/数字/下划线",
      "exampleText": "Pass1234"
    }
  ]
